# Template — copy to .env.development and fill in real values.
# This file is committed. Never put real secrets here.

NODE_ENV=development
PORT=5000

MONGODB_URI=mongodb://localhost:27017/reviewboost_dev
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars
JWT_EXPIRES_IN=7d

CLAUDE_API_KEY=sk-ant-your-key-here
ADMIN_SECRET=replace-with-your-admin-secret
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=replace-with-strong-password

LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:5173

# Frontend URL — used in invite/welcome email links
FRONTEND_URL=http://localhost:5173

# SMTP — used for sending invite, welcome, and review alert emails
# Gmail: use an App Password (not your real password) from https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password-here
SMTP_FROM=ReviewBoost <your-gmail@gmail.com>
